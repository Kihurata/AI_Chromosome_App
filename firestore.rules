rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: allow authenticated users to read/write all other documents
    // (Note: In a real production app, you should refine this further per collection)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
